{
  "name": "rathch/randomdata",
  "description": "TYPO3 extensions to generate new random data or replace existing data with random data",
  "type": "typo3-cms-extension",
  "license": "GPL-3.0-or-later",
  "version": "1.0.0",
  "require": {
    "typo3/cms-core": "^9.5 || ^10.4 || ^11.5",
    "fzaninotto/faker": "*"
  },
  "replace": {
    "typo3-ter/randomdata": "self.version"
  },
  "autoload": {
    "psr-4": {
      "WIND\\Randomdata\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "randomdata"
    }
  }
}
